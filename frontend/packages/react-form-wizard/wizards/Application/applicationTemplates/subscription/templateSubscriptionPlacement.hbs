{{! ========================================================== }}
{{! ========================================================== }}
{{! ================== Placement ============================= }}
{{! ========================================================== }}
{{! ========================================================== }}
  placement:
    placementRef:
      kind: Placement
{{#if selectedPlacementName}}
      name: {{{selectedPlacementName}}}
{{else}}
      name: {{{@root.name}}}-placement-{{{@root.uniqueGroupID}}}
{{/if}}
{{#if deployment}}
{{#if_ne deployment.window 'always'}}
  timewindow:
    windowtype: {{{deployment.window}}}
    location: {{{timeWindow.timezone}}}
    daysofweek: [{{{timewindow.daysofweek}}}]
    hours:
  {{#if timeWindows}}
  {{#each timeWindows}}
      - start: "{{start}}"
        end: "{{end}}"
  {{/each}}
  {{/if}}
{{/if_ne}}
{{/if}}
{{#unless existing-placement-checkbox}}
---
apiVersion: cluster.open-cluster-management.io/v1beta1
kind: Placement
metadata:
  labels:
    app: {{{@root.name}}}
  name: {{{@root.name}}}-placement-{{{@root.uniqueGroupID}}}
  namespace: {{{@root.namespace}}}
  {{#if selfLinks}}
  selfLink: {{{selfLinks.Placement}}}
  {{/if}}
{{#if clusterSelector.mode}}
spec:
  predicates:
    - requiredClusterSelector:
        labelSelector:
          matchLabels:
            {{#each clusterSelector.clusterLabelsList}}
            {{#if validValue}}
            '{{{labelName}}}': '{{{labelValue}}}'
            {{/if}}
            {{/each}}
{{else}}
spec:
  {{#if local-cluster-checkbox}}
  predicates:
    - requiredClusterSelector:
        labelSelector:
          matchLabels:
            'local-cluster': 'true'
  {{/if}}
{{/if}}
{{/unless}}
